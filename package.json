{
  "name": "w-claude-slave",
  "displayName": "W_Claude_Slave",
  "description": "A Warcraft grunt lives in VS Code and does Claude Code's dirty work — 'Work, work!' when you send a command, 'Job's done!' at the end, and mutters if you poke him. Zug zug.",
  "version": "0.1.0",
  "publisher": "ParkerShot",
  "license": "MIT",
  "author": "WebB0rn (ParkerShot)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ParkerShot/W_Claude_Slave"
  },
  "bugs": {
    "url": "https://github.com/ParkerShot/W_Claude_Slave/issues"
  },
  "homepage": "https://github.com/ParkerShot/W_Claude_Slave#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "wClaudeSlave",
          "title": "W_Claude_Slave",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "wClaudeSlave": [
        {
          "type": "webview",
          "id": "wClaudeSlave.view",
          "name": "W_Claude_Slave"
        }
      ]
    },
    "configuration": {
      "title": "W_Claude_Slave",
      "properties": {
        "wClaudeSlave.slaveHome": {
          "type": "string",
          "default": "",
          "description": "Папка с events.jsonl и assets. Пусто = ~/.claude/w-claude-slave"
        },
        "wClaudeSlave.muted": {
          "type": "boolean",
          "default": false,
          "description": "Выключить звук"
        },
        "wClaudeSlave.subtitles": {
          "type": "boolean",
          "default": true,
          "description": "Показывать фразы в облачке"
        },
        "wClaudeSlave.workingTimeoutMinutes": {
          "type": "number",
          "default": 20,
          "description": "Через сколько минут без событий сбросить состояние «работает» (если Stop не пришёл)"
        },
        "wClaudeSlave.reactionSeconds": {
          "type": "number",
          "default": 6,
          "description": "Сколько секунд играть анимацию-реакцию, прежде чем вернуться к статичному портрету"
        },
        "wClaudeSlave.idleGrumble": {
          "type": "boolean",
          "default": false,
          "description": "Иногда бурчать в простое"
        },
        "wClaudeSlave.idleGrumbleMinutes": {
          "type": "number",
          "default": 7,
          "description": "Примерно раз в сколько минут бурчать в простое"
        }
      }
    }
  }
}
