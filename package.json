{
  "name": "warcraft-slave",
  "displayName": "Warcraft Slave",
  "description": "Раб из Warcraft 3 реагирует на команды Claude Code: говорит фразы, работает, бурчит.",
  "version": "0.1.0",
  "publisher": "otsni",
  "license": "MIT",
  "author": "WebB0rn (ParkerShot)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ParkerShot/vscode-warcraft-slave"
  },
  "bugs": {
    "url": "https://github.com/ParkerShot/vscode-warcraft-slave/issues"
  },
  "homepage": "https://github.com/ParkerShot/vscode-warcraft-slave#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "warcraftSlave",
          "title": "Slave",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "warcraftSlave": [
        {
          "type": "webview",
          "id": "warcraftSlave.view",
          "name": "Slave"
        }
      ]
    },
    "configuration": {
      "title": "Warcraft Slave",
      "properties": {
        "warcraftSlave.slaveHome": {
          "type": "string",
          "default": "",
          "description": "Папка с events.jsonl и assets. Пусто = ~/.claude/slave"
        },
        "warcraftSlave.muted": {
          "type": "boolean",
          "default": false,
          "description": "Выключить звук"
        },
        "warcraftSlave.subtitles": {
          "type": "boolean",
          "default": true,
          "description": "Показывать фразы в облачке"
        },
        "warcraftSlave.workingTimeoutMinutes": {
          "type": "number",
          "default": 20,
          "description": "Через сколько минут без событий сбросить состояние «работает» (если Stop не пришёл)"
        },
        "warcraftSlave.reactionSeconds": {
          "type": "number",
          "default": 6,
          "description": "Сколько секунд играть анимацию-реакцию, прежде чем вернуться к статичному портрету"
        },
        "warcraftSlave.idleGrumble": {
          "type": "boolean",
          "default": false,
          "description": "Иногда бурчать в простое"
        },
        "warcraftSlave.idleGrumbleMinutes": {
          "type": "number",
          "default": 7,
          "description": "Примерно раз в сколько минут бурчать в простое"
        }
      }
    }
  }
}
